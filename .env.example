# Backend
ENVIRONMENT=development
DATABASE_URL=sqlite+aiosqlite:///./agentic_factcheck.db
JWT_SECRET=replace-with-long-random-secret
KEY_ENCRYPTION_SECRET=replace-with-long-random-encryption-secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEFAULT_SEARCH_PROVIDER=duckduckgo
DUCKDUCKGO_TIMEOUT=8
PROVIDER_TIMEOUT=45
JOB_WORKER_COUNT=2

# Optional deployment/provider defaults. BYOK keys can also be stored per user.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
TAVILY_API_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
